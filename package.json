{
  "name": "rubous-tech-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend && mv frontend/dist ./dist",
    "preview": "npm run preview -w frontend",
    "lint": "npm run lint -w frontend",
    "backend:start": "npm run start -w backend",
    "gsd:install": "npx get-shit-done-cc --antigravity --local",
    "gsd:map": "npx get-shit-done-cc --map-codebase",
    "ralph:run": "npx tsx scripts/ralph-loop.mjs",
    "frontend":"cd frontend && npm run dev",
    "backend":"cd backend && npm run dev"
  },
