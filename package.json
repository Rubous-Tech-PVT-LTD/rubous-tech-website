{
  "name": "rubous-tech-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev -w backend",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "backend:start": "npm run start -w backend",
    "gsd:install": "npx get-shit-done-cc --antigravity --local",
    "gsd:map": "npx get-shit-done-cc --map-codebase",
    "ralph:run": "npx tsx scripts/ralph-loop.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "get-shit-done-cc": "^1.34.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.9",
    "ralph-loop-agent": "^0.0.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "vite": "^8.0.4",
    "zod": "^4.3.6"
  }
